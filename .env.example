# Little to Large Environment Variables Example
PORT=3000
JWT_SECRET=replace_with_a_long_random_secret_string

# MySQL Configuration (Omit these to run in SQLite3 fallback mode)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_secure_password
DB_NAME=little_to_large
DB_PORT=3306

# Razorpay Payment Gateway Keys (Generate from Dashboard -> Settings -> API Keys)
RAZORPAY_KEY_ID=rzp_test_yourKeyHere
RAZORPAY_KEY_SECRET=yourSecretHere
